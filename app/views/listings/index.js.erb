// Reset markers, then add new ones
markers.forEach((m) => m.remove())
markers = []
<% @listings.each do |listing| %>
  var marker = L.marker(
    [<%= listing.lat %>, <%= listing.lng %>],
    {icon: marker_icons.<%= listing.marker_icon(@price_spread, @latest_import) %>}
  ).addTo(map)
  marker.bindPopup(`
    <a target="_blank" rel="noreferrer noopener" href="<%= listing.external_url %>"><img class="photo" src="<%= listing.tooltip_photo %>"/></a></br>
    <%= listing.address %>
    <br/>
    <strong>$<%= listing.price/1000 %>k</strong> -
    <%= image_tag("bed", class: "icon") %> <%= listing.bedrooms %>
    <%= image_tag("bath", class: "icon") %> <%= listing.bathrooms %>
    <br/>
    Added <%= listing.created_at.strftime("%b %d") %> - Updated <%= listing.imported_at.strftime("%b %d") %>
  `)
  markers.push(marker)
<% end %>
console.log("Listings: ", <%= @listings.size %>)

document.getElementById('map_legend_prices').innerHTML = `
<% 7.times do |i| %>
  <% if @price_spread[i] > 0 %>
  <%= number_to_currency(@price_spread[i]/1000, precision: 0) %>k
  <% end %>
  <%= image_tag("house#{i+1}") %>
<% end %>
<button popovertarget="search_filters">Edit</button>
`
